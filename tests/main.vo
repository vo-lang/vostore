func testFreeListReuse(tmpDir string) {
	path := filepath.Join(tmpDir, "free_list_reuse.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for free list reuse")

	first := make([]byte, 5000)
	for i := 0; i < len(first); i++ {
		first[i] = byte((i * 3) % 251)
	}
	second := make([]byte, 5000)
	for i := 0; i < len(second); i++ {
		second[i] = byte((i * 5) % 241)
	}

	err = db.SetBytes("big", first)
	assert(err == nil, "set first value for free list reuse")
	err = db.Close()
	assert(err == nil, "close db after first value for free list reuse")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for delete in free list reuse")
	found, err := db.Delete("big")
	assert(err == nil, "delete value for free list reuse")
	assert(found, "delete should find existing value for free list reuse")
	err = db.Close()
	assert(err == nil, "close db after delete for free list reuse")

	pageCountAfterDelete, freeCountAfterDelete := readPrimaryHeaderCounts(path)
	assert(freeCountAfterDelete >= 3, "delete should populate free list")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for reinsertion in free list reuse")
	err = db.SetBytes("again", second)
	assert(err == nil, "set second value for free list reuse")
	err = db.Close()
	assert(err == nil, "close db after second value for free list reuse")

	pageCountAfterReuse, freeCountAfterReuse := readPrimaryHeaderCounts(path)
	assert(pageCountAfterReuse == pageCountAfterDelete, "page reuse should avoid growing pageCount")
	assert(freeCountAfterReuse < freeCountAfterDelete, "page reuse should consume free pages")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db to verify reused value")
	got, ok, err := db.GetBytes("again")
	assert(err == nil, "get reused value err")
	assert(ok, "get reused value found")
	assert(len(got) == len(second), "reused value length")
	for i := 0; i < len(got); i++ {
		assert(got[i] == second[i], "reused value byte mismatch")
	}
	err = db.Close()
	assert(err == nil, "close db after verifying reused value")
}

func testPendingFreeRecovery(tmpDir string) {
	path := filepath.Join(tmpDir, "pending_free_recovery.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for pending free recovery")

	first := make([]byte, 5000)
	for i := 0; i < len(first); i++ {
		first[i] = byte((i * 7) % 251)
	}
	second := make([]byte, 5000)
	for i := 0; i < len(second); i++ {
		second[i] = byte((i * 11) % 241)
	}

	err = db.SetBytes("big", first)
	assert(err == nil, "set first value for pending free recovery")
	err = db.Close()
	assert(err == nil, "close db after first value for pending free recovery")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for delete in pending free recovery")
	found, err := db.Delete("big")
	assert(err == nil, "delete value for pending free recovery")
	assert(found, "delete should find existing key for pending free recovery")
	err = db.Close()
	assert(err == nil, "close db after delete for pending free recovery")

	pageCountAfterDelete, freeHeadAfterDelete, freeCountAfterDelete, pendingHeadAfterDelete, pendingCountAfterDelete := readPrimaryHeaderState(path)
	assert(freeCountAfterDelete >= 3, "delete should create reusable pages for pending free recovery")
	assert(pendingHeadAfterDelete == 0, "pending free head should be clear before synthetic recovery")
	assert(pendingCountAfterDelete == 0, "pending free count should be clear before synthetic recovery")

	pendingHead := freeHeadAfterDelete
	headPage := readPageBytes(path, pendingHead)
	if headPage[0] == 3 {
		freeIDs := readFreeListIDs(path, freeHeadAfterDelete, freeCountAfterDelete)
		assert(len(freeIDs) == int(freeCountAfterDelete), "free list ids count before synthetic pending recovery")
		pendingIDs := make([]uint32, len(freeIDs)-1)
		for i := 1; i < len(freeIDs); i++ {
			pendingIDs[i-1] = freeIDs[i]
		}
		err = writePageBytes(path, pendingHead, marshalTestPendingPage(0, pendingIDs))
		assert(err == nil, "rewrite pending page for pending free recovery")
	} else {
		assert(headPage[0] == 5, "pending free recovery head page type")
	}

	buf := readHeaderBytes(path)
	binary.LittleEndian.PutUint32(buf[testOffFreeHead:], 0)
	binary.LittleEndian.PutUint32(buf[testOffFreeCount:], 0)
	binary.LittleEndian.PutUint32(buf[testOffPendingFreeHead:], pendingHead)
	binary.LittleEndian.PutUint32(buf[testOffPendingFreeCount:], freeCountAfterDelete)
	rewriteHeaderChecksum(buf[:testHeaderSize])
	binary.LittleEndian.PutUint32(buf[testHeaderSize+testOffFreeHead:], 0)
	binary.LittleEndian.PutUint32(buf[testHeaderSize+testOffFreeCount:], 0)
	binary.LittleEndian.PutUint32(buf[testHeaderSize+testOffPendingFreeHead:], pendingHead)
	binary.LittleEndian.PutUint32(buf[testHeaderSize+testOffPendingFreeCount:], freeCountAfterDelete)
	rewriteHeaderChecksum(buf[testHeaderSize:testHeaderTotal])
	err = writeHeaderBytes(path, buf)
	assert(err == nil, "rewrite header into pending state for pending free recovery")

	db, err = vostore.Open(path)
	assert(err == nil, "open db from synthetic pending state")
	_, ok, err := db.GetBytes("big")
	assert(err == nil, "get deleted key after pending free recovery")
	assert(!ok, "deleted key should stay deleted after pending free recovery")
	pageCountRecovered, freeHeadRecovered, freeCountRecovered, pendingHeadRecovered, pendingCountRecovered := readPrimaryHeaderState(path)
	assert(pageCountRecovered == pageCountAfterDelete, "page count should remain stable after pending free recovery")
	assert(freeHeadRecovered != 0, "free head should be restored after pending free recovery")
	assert(freeCountRecovered == freeCountAfterDelete, "free count should be restored after pending free recovery")
	assert(pendingHeadRecovered == 0, "pending free head should be cleared after pending free recovery")
	assert(pendingCountRecovered == 0, "pending free count should be cleared after pending free recovery")

	err = db.SetBytes("again", second)
	assert(err == nil, "set second value after pending free recovery")
	err = db.Close()
	assert(err == nil, "close db after reuse in pending free recovery")

	pageCountAfterReuse, _, freeCountAfterReuse, pendingHeadAfterReuse, pendingCountAfterReuse := readPrimaryHeaderState(path)
	assert(pageCountAfterReuse == pageCountAfterDelete, "pending free recovery should preserve page reuse")
	assert(freeCountAfterReuse < freeCountRecovered, "pending free recovery should consume free pages on reuse")
	assert(pendingHeadAfterReuse == 0, "pending free head should stay clear after reuse")
	assert(pendingCountAfterReuse == 0, "pending free count should stay clear after reuse")
	assertStructuralInvariants(path)

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db to verify pending free recovery value")
	got, ok, err := db.GetBytes("again")
	assert(err == nil, "get reused value after pending free recovery")
	assert(ok, "reused value should exist after pending free recovery")
	assert(len(got) == len(second), "reused value length after pending free recovery")
	for i := 0; i < len(got); i++ {
		assert(got[i] == second[i], "reused value byte after pending free recovery")
	}
	err = db.Close()
	assert(err == nil, "close db after verifying pending free recovery")
	assertStructuralInvariants(path)
}

func testOverflowCycleDetected(tmpDir string) {
	path := filepath.Join(tmpDir, "overflow_cycle_detected.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for overflow cycle detected")

	large := make([]byte, 5000)
	for i := 0; i < len(large); i++ {
		large[i] = byte((i * 7) % 251)
	}
	err = db.SetBytes("big", large)
	assert(err == nil, "set large value for overflow cycle detected")
	err = db.Close()
	assert(err == nil, "close db for overflow cycle detected")

	overflowID := readSingleLeafOverflowID(path)
	page := readPageBytes(path, overflowID)
	binary.LittleEndian.PutUint32(page[4:8], overflowID)
	err = writePageBytes(path, overflowID, page)
	assert(err == nil, "rewrite overflow page into a cycle")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for overflow cycle detected")
	_, _, err = db.GetBytes("big")
	assert(err != nil, "overflow cycle should fail on read")
	err = db.Close()
	assert(err == nil, "close db for overflow cycle detected")
}

func testModelRandomOps(tmpDir string) {
	path := filepath.Join(tmpDir, "model_random_ops.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for model random ops")

	for _, seed := range []uint32{1} {
		model := make(map[string]string)
		state := seed
		err = db.Clear()
		assert(err == nil, "clear before model random seed")

		for step := 0; step < 80; step++ {
			state = nextTestRand(state)
			op := int(state % 6)
			key := testKeyForState(state)
			value := fmt.Sprintf("value-%d-%d-%s", seed, step, key)

			switch op {
			case 0, 1:
				err = db.Set(key, value)
				assert(err == nil, "model random set")
				model[key] = value
			case 2:
				found, deleteErr := db.Delete(key)
				assert(deleteErr == nil, "model random delete")
				_, existed := model[key]
				assert(found == existed, "model random delete found parity")
				delete(model, key)
			case 3:
				got, ok, getErr := db.Get(key)
				assert(getErr == nil, "model random get")
				expected, existed := model[key]
				assert(ok == existed, "model random get existence parity")
				if existed {
					assert(got == expected, "model random get value parity")
				}
			case 4:
				has, hasErr := db.Has(key)
				assert(hasErr == nil, "model random has")
				_, existed := model[key]
				assert(has == existed, "model random has parity")
			case 5:
				if step%17 == 0 {
					err = db.Clear()
					assert(err == nil, "model random clear")
					model = make(map[string]string)
				} else {
					batchKeyA := testKeyForState(state + 17)
					batchKeyB := testKeyForState(state + 31)
					batchValueA := fmt.Sprintf("batch-%d-%d-a", seed, step)
					err = db.Update(func(tx *vostore.Tx) error {
						tx.Set(batchKeyA, batchValueA)?
						_, deleteErr := tx.Delete(batchKeyB)
						deleteErr?
						return nil
					})
					assert(err == nil, "model random batch update")
					model[batchKeyA] = batchValueA
					delete(model, batchKeyB)
				}
			}

			if step%20 == 19 {
				err = db.Close()
				assert(err == nil, "close db during model random ops")
				assertStructuralInvariants(path)
				db, err = vostore.Open(path)
				assert(err == nil, "reopen db during model random ops")
				assertModelMatchesStore(db, model)
			}
		}
		assertModelMatchesStore(db, model)
		assertStructuralInvariants(path)
	}

	err = db.Close()
	assert(err == nil, "close db for model random ops")
}

func testModelRandomBytesOps(tmpDir string) {
	path := filepath.Join(tmpDir, "model_random_bytes_ops.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for model random bytes ops")

	for _, seed := range []uint32{7} {
		model := make(map[string][]byte)
		state := seed
		err = db.Clear()
		assert(err == nil, "clear before model random bytes seed")

		for step := 0; step < 60; step++ {
			state = nextTestRand(state)
			op := int(state % 7)
			key := fmt.Sprintf("blob-%02d", int(state%23))
			value := testBytesForState(seed, step, state)

			switch op {
			case 0, 1, 2:
				err = db.SetBytes(key, value)
				assert(err == nil, fmt.Sprintf("model random bytes set: %v", err))
				model[key] = cloneTestBytes(value)
			case 3:
				found, deleteErr := db.Delete(key)
				assert(deleteErr == nil, "model random bytes delete")
				_, existed := model[key]
				assert(found == existed, "model random bytes delete found parity")
				delete(model, key)
			case 4:
				got, ok, getErr := db.GetBytes(key)
				assert(getErr == nil, "model random bytes get")
				expected, existed := model[key]
				assert(ok == existed, "model random bytes get existence parity")
				if existed {
					assert(bytesEqual(got, expected), "model random bytes get value parity")
				}
			case 5:
				batchKeyA := fmt.Sprintf("blob-%02d", int((state+11)%23))
				batchKeyB := fmt.Sprintf("blob-%02d", int((state+19)%23))
				batchValueA := testBytesForState(seed+13, step+1, state+29)
				err = db.Update(func(tx *vostore.Tx) error {
					tx.SetBytes(batchKeyA, batchValueA)?
					_, deleteErr := tx.Delete(batchKeyB)
					deleteErr?
					return nil
				})
				assert(err == nil, "model random bytes batch update")
				model[batchKeyA] = cloneTestBytes(batchValueA)
				delete(model, batchKeyB)
			case 6:
				if step%19 == 0 {
					err = db.Clear()
					assert(err == nil, "model random bytes clear")
					model = make(map[string][]byte)
				} else {
					has, hasErr := db.Has(key)
					assert(hasErr == nil, "model random bytes has")
					_, existed := model[key]
					assert(has == existed, "model random bytes has parity")
				}
			}

			if step%20 == 19 {
				err = db.Close()
				assert(err == nil, "close db during model random bytes ops")
				assertStructuralInvariants(path)
				db, err = vostore.Open(path)
				assert(err == nil, "reopen db during model random bytes ops")
				assertModelBytesMatchesStore(db, model)
			}
		}
		assertModelBytesMatchesStore(db, model)
		assertStructuralInvariants(path)
	}

	err = db.Close()
	assert(err == nil, "close db for model random bytes ops")
}

func testTransactionCleanupOnPanic(tmpDir string) {
	path := filepath.Join(tmpDir, "tx_cleanup_panic.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for tx cleanup on panic")

	panicValue, didPanic := capturePanic(func() {
		db.Update(func(tx *vostore.Tx) error {
			tx.Set("during-panic", "value")?
			panic("update panic")
		})
	})
	assert(didPanic, "update panic should propagate")
	assert(panicValue.(string) == "update panic", "update panic value should be preserved")

	_, ok, err := db.Get("during-panic")
	assert(err == nil, "get value after panicking update err")
	assert(!ok, "panicking update must rollback")
	err = db.Set("after-update-panic", "ok")
	assert(err == nil, "store should remain usable after update panic")

	panicValue, didPanic = capturePanic(func() {
		db.View(func(tx *vostore.Tx) error {
			_, _, err := tx.Get("after-update-panic")
			assert(err == nil, "read inside panic view")
			panic("view panic")
		})
	})
	assert(didPanic, "view panic should propagate")
	assert(panicValue.(string) == "view panic", "view panic value should be preserved")

	err = db.Set("after-view-panic", "still-ok")
	assert(err == nil, "store should remain usable after view panic")
	val, ok, err := db.Get("after-view-panic")
	assert(err == nil, "get value after view panic err")
	assert(ok, "value after view panic should exist")
	assert(val == "still-ok", "value after view panic")

	err = db.Close()
	assert(err == nil, "close db for tx cleanup on panic")
}

// padNum converts an int to a zero-padded string of given width.
func padNum(n, width int) string {
	s := fmt.Sprintf("%d", n)
	for len(s) < width {
		s = "0" + s
	}
	return s
}

func largeTreeValue(prefix string) string {
	return prefix + ":0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
}

const (
	testHeaderSize = 64
	testHeaderTotal = 128
	testOffPageSize = 8
	testOffRootPage = 16
	testOffFreeHead = 20
	testOffPageCount = 12
	testOffFreeCount = 24
	testOffPendingFreeHead = 28
	testOffPendingFreeCount = 32
	testOffTxID = 36
	testOffChecksum = 40
)

func capturePanic(fn func()) (any, bool) {
	var recovered any
	var didPanic bool
	func() {
		defer func() {
			recovered = recover()
			didPanic = recovered != nil
		}()
		fn()
	}()
	return recovered, didPanic
}

func readHeaderBytes(path string) []byte {
	buf, err := os.ReadFile(path)
	assert(err == nil, "read header bytes")
	assert(len(buf) >= testHeaderTotal, "header bytes length")
	result := make([]byte, testHeaderTotal)
	copy(result, buf[:testHeaderTotal])
	return result
}

func writeHeaderBytes(path string, header []byte) error {
	buf := os.ReadFile(path)?
	if len(buf) < testHeaderTotal {
		return fmt.Errorf("header bytes length")
	}
	copy(buf[:testHeaderTotal], header)
	return os.WriteFile(path, buf, 0644)
}

func readPrimaryHeaderCounts(path string) (uint32, uint32) {
	buf := readHeaderBytes(path)
	pageCount := binary.LittleEndian.Uint32(buf[testOffPageCount:])
	freeCount := binary.LittleEndian.Uint32(buf[testOffFreeCount:])
	return pageCount, freeCount
}

func readPrimaryHeaderState(path string) (uint32, uint32, uint32, uint32, uint32) {
	buf := readHeaderBytes(path)
	pageCount := binary.LittleEndian.Uint32(buf[testOffPageCount:])
	freeHead := binary.LittleEndian.Uint32(buf[testOffFreeHead:])
	freeCount := binary.LittleEndian.Uint32(buf[testOffFreeCount:])
	pendingFreeHead := binary.LittleEndian.Uint32(buf[testOffPendingFreeHead:])
	pendingFreeCount := binary.LittleEndian.Uint32(buf[testOffPendingFreeCount:])
	return pageCount, freeHead, freeCount, pendingFreeHead, pendingFreeCount
}

func readPrimaryRootPage(path string) uint32 {
	buf := readHeaderBytes(path)
	return binary.LittleEndian.Uint32(buf[testOffRootPage:])
}

func readPageBytes(path string, pageID uint32) []byte {
	buf, err := os.ReadFile(path)
	assert(err == nil, "read page bytes")
	offset := int(pageID) * 4096
	assert(len(buf) >= offset+4096, "page bytes length")
	result := make([]byte, 4096)
	copy(result, buf[offset:offset+4096])
	return result
}

func writePageBytes(path string, pageID uint32, page []byte) error {
	buf := os.ReadFile(path)?
	offset := int(pageID) * 4096
	if len(buf) < offset+4096 {
		return fmt.Errorf("page bytes length")
	}
	copy(buf[offset:offset+4096], page)
	return os.WriteFile(path, buf, 0644)
}

func readFreeListIDs(path string, head uint32, count uint32) []uint32 {
	ids := make([]uint32, 0, count)
	current := head
	for current != 0 {
		ids = append(ids, current)
		page := readPageBytes(path, current)
		if page[0] == 3 {
			current = binary.LittleEndian.Uint32(page[4:8])
			continue
		}
		assert(page[0] == 5, "free list ids page type")
		entryCount := int(binary.LittleEndian.Uint16(page[8:10]))
		assert(10+entryCount*4 <= 4096, "free list ids pending payload bounds")
		pos := 10
		for i := 0; i < entryCount; i++ {
			id := binary.LittleEndian.Uint32(page[pos : pos+4])
			assert(id != 0, "free list ids pending entry")
			ids = append(ids, id)
			pos += 4
		}
		current = binary.LittleEndian.Uint32(page[4:8])
	}
	return ids
}

func marshalTestPendingPage(next uint32, ids []uint32) []byte {
	buf := make([]byte, 4096)
	buf[0] = 5
	binary.LittleEndian.PutUint32(buf[4:], next)
	binary.LittleEndian.PutUint16(buf[8:], uint16(len(ids)))
	pos := 10
	for _, id := range ids {
		binary.LittleEndian.PutUint32(buf[pos:], id)
		pos += 4
	}
	return buf
}

func testHugeKey(last byte) string {
	buf := make([]byte, 4000)
	for i := 0; i < len(buf)-1; i++ {
		buf[i] = 'k'
	}
	buf[len(buf)-1] = last
	return string(buf)
}

func readSingleLeafOverflowID(path string) uint32 {
	rootPage := readPrimaryRootPage(path)
	page := readPageBytes(path, rootPage)
	cellCount := int(binary.LittleEndian.Uint16(page[2:4]))
	assert(cellCount == 1, "single leaf overflow cell count")
	offset := int(binary.LittleEndian.Uint16(page[12:14]))
	assert(offset >= 12 && offset < 4096, "single leaf overflow offset")
	keyLen := int(binary.LittleEndian.Uint16(page[offset : offset+2]))
	rawValLen := binary.LittleEndian.Uint32(page[offset+2 : offset+6])
	assert(rawValLen&0x80000000 != 0, "single leaf should store overflow pointer")
	overflowPos := offset + 6 + keyLen
	assert(overflowPos+4 <= 4096, "single leaf overflow pointer bounds")
	return binary.LittleEndian.Uint32(page[overflowPos : overflowPos+4])
}

func nextTestRand(state uint32) uint32 {
	return state*1664525 + 1013904223
}

func testKeyForState(state uint32) string {
	return fmt.Sprintf("key-%02d", int(state%37))
}

func assertModelMatchesStore(db *vostore.Store, model map[string]string) {
	n, err := db.Len()
	assert(err == nil, "model parity len err")
	assert(n == len(model), "model parity len")

	keys, err := db.Keys("")
	assert(err == nil, "model parity keys err")
	expectedKeys := sortedModelKeys(model)
	assert(len(keys) == len(expectedKeys), "model parity keys count")
	for i := 0; i < len(keys); i++ {
		assert(keys[i] == expectedKeys[i], "model parity key order")
		value, ok, getErr := db.Get(keys[i])
		assert(getErr == nil, "model parity key get err")
		assert(ok, "model parity key should exist")
		assert(value == model[keys[i]], "model parity key value")
	}

	for key, expected := range model {
		value, ok, getErr := db.Get(key)
		assert(getErr == nil, "model parity direct get err")
		assert(ok, "model parity direct get exists")
		assert(value == expected, "model parity direct get value")
		has, hasErr := db.Has(key)
		assert(hasErr == nil, "model parity direct has err")
		assert(has, "model parity direct has exists")
	}

	missingKey := "key-missing"
	_, exists := model[missingKey]
	assert(!exists, "model parity missing key assumption")
	_, ok, getErr := db.Get(missingKey)
	assert(getErr == nil, "model parity missing get err")
	assert(!ok, "model parity missing get")
	has, hasErr := db.Has(missingKey)
	assert(hasErr == nil, "model parity missing has err")
	assert(!has, "model parity missing has")

	for prefixDigit := 0; prefixDigit < 4; prefixDigit++ {
		prefix := fmt.Sprintf("key-%1d", prefixDigit)
		prefixKeys, prefixErr := db.Keys(prefix)
		assert(prefixErr == nil, "model parity prefix keys err")
		expectedPrefixKeys := filteredModelKeys(model, prefix)
		assert(len(prefixKeys) == len(expectedPrefixKeys), "model parity prefix keys count")
		for i := 0; i < len(prefixKeys); i++ {
			assert(prefixKeys[i] == expectedPrefixKeys[i], "model parity prefix key order")
		}
	}
}

func sortedModelKeys(model map[string]string) []string {
	keys := make([]string, 0, len(model))
	for key := range model {
		keys = append(keys, key)
	}
	for i := 1; i < len(keys); i++ {
		j := i
		for j > 0 && keys[j] < keys[j-1] {
			keys[j], keys[j-1] = keys[j-1], keys[j]
			j--
		}
	}
	return keys
}

func filteredModelKeys(model map[string]string, prefix string) []string {
	keys := make([]string, 0)
	for key := range model {
		if len(key) >= len(prefix) && key[:len(prefix)] == prefix {
			keys = append(keys, key)
		}
	}
	for i := 1; i < len(keys); i++ {
		j := i
		for j > 0 && keys[j] < keys[j-1] {
			keys[j], keys[j-1] = keys[j-1], keys[j]
			j--
		}
	}
	return keys
}

func assertStructuralInvariants(path string) {
	buf := readHeaderBytes(path)
	pageCount := binary.LittleEndian.Uint32(buf[testOffPageCount:])
	rootPage := binary.LittleEndian.Uint32(buf[testOffRootPage:])
	freeHead := binary.LittleEndian.Uint32(buf[testOffFreeHead:])
	freeCount := binary.LittleEndian.Uint32(buf[testOffFreeCount:])
	pendingFreeHead := binary.LittleEndian.Uint32(buf[testOffPendingFreeHead:])
	pendingFreeCount := binary.LittleEndian.Uint32(buf[testOffPendingFreeCount:])
	fileBuf, err := os.ReadFile(path)
	assert(err == nil, "structural invariant read file")
	assert(len(fileBuf) == int(pageCount)*4096, "structural invariant file size")
	assert(pendingFreeHead == 0, "structural invariant pending free head cleared")
	assert(pendingFreeCount == 0, "structural invariant pending free count cleared")

	treePages := make(map[uint32]bool)
	overflowPages := make(map[uint32]bool)
	freePages := make(map[uint32]bool)

	if rootPage != 0 {
		collectTreePages(path, rootPage, treePages, overflowPages)
		collectFirstKeyAndValidateSeparators(path, rootPage, make(map[uint32]bool))
	}
	collectFreePages(path, freeHead, freePages)
	assert(uint32(len(freePages)) == freeCount, "structural invariant free count matches free list")

	for pageID := range treePages {
		assert(!overflowPages[pageID], "structural invariant tree/overflow disjoint")
		assert(!freePages[pageID], "structural invariant tree/free disjoint")
	}
	for pageID := range overflowPages {
		assert(!freePages[pageID], "structural invariant overflow/free disjoint")
	}

	for pageID := uint32(1); pageID < pageCount; pageID++ {
		assert(treePages[pageID] || overflowPages[pageID] || freePages[pageID], "structural invariant page coverage")
	}
}

func collectFirstKeyAndValidateSeparators(path string, pageID uint32, seen map[uint32]bool) string {
	assert(pageID != 0, "separator invariant page id")
	assert(!seen[pageID], "separator invariant btree cycle")
	seen[pageID] = true
	page := readPageBytes(path, pageID)
	pageType := page[0]
	cellCount := int(binary.LittleEndian.Uint16(page[2:4]))
	assert(cellCount >= 0, "separator invariant cell count")
	if pageType == 1 {
		assert(cellCount > 0, "separator invariant leaf must be non-empty")
		return pageFirstKey(page)
	}
	assert(pageType == 2, "separator invariant interior page type")
	rightChild := binary.LittleEndian.Uint32(page[4:8])
	assert(rightChild != 0, "separator invariant interior right child")
	if cellCount == 0 {
		return collectFirstKeyAndValidateSeparators(path, rightChild, seen)
	}
	childFirstKeys := make([]string, cellCount+1)
	for i := 0; i < cellCount; i++ {
		off := int(binary.LittleEndian.Uint16(page[12+i*2 : 14+i*2]))
		childPage := binary.LittleEndian.Uint32(page[off : off+4])
		childFirstKeys[i] = collectFirstKeyAndValidateSeparators(path, childPage, seen)
	}
	childFirstKeys[cellCount] = collectFirstKeyAndValidateSeparators(path, rightChild, seen)
	for i := 0; i < cellCount; i++ {
		off := int(binary.LittleEndian.Uint16(page[12+i*2 : 14+i*2]))
		keyLen := int(binary.LittleEndian.Uint16(page[off+4 : off+6]))
		sepKey := string(page[off+6 : off+6+keyLen])
		assert(sepKey == childFirstKeys[i+1], "separator invariant matches right child first key")
	}
	return childFirstKeys[0]
}

func pageFirstKey(page []byte) string {
	cellCount := int(binary.LittleEndian.Uint16(page[2:4]))
	assert(cellCount > 0, "page first key requires non-empty page")
	off := int(binary.LittleEndian.Uint16(page[12:14]))
	keyLen := int(binary.LittleEndian.Uint16(page[off : off+2]))
	return string(page[off+6 : off+6+keyLen])
}

func collectTreePages(path string, pageID uint32, treePages map[uint32]bool, overflowPages map[uint32]bool) {
	if pageID == 0 {
		return
	}
	assert(!treePages[pageID], "structural invariant btree cycle")
	treePages[pageID] = true
	page := readPageBytes(path, pageID)
	pageType := page[0]
	assert(pageType == 1 || pageType == 2, "structural invariant node page type")
	cellCount := int(binary.LittleEndian.Uint16(page[2:4]))
	offsetEnd := 12 + cellCount*2
	assert(offsetEnd <= 4096, "structural invariant offset table fits")
	for i := 0; i < cellCount; i++ {
		off := int(binary.LittleEndian.Uint16(page[12+i*2 : 14+i*2]))
		assert(off >= offsetEnd && off < 4096, "structural invariant cell offset bounds")
		if pageType == 1 {
			assert(off+6 <= 4096, "structural invariant leaf header bounds")
			keyLen := int(binary.LittleEndian.Uint16(page[off : off+2]))
			rawValLen := binary.LittleEndian.Uint32(page[off+2 : off+6])
			pos := off + 6 + keyLen
			assert(pos <= 4096, "structural invariant leaf key bounds")
			if rawValLen&0x80000000 != 0 {
				assert(pos+4 <= 4096, "structural invariant overflow pointer bounds")
				overflowID := binary.LittleEndian.Uint32(page[pos : pos+4])
				collectOverflowPages(path, overflowID, overflowPages)
			} else {
				valLen := int(rawValLen)
				assert(pos+valLen <= 4096, "structural invariant inline value bounds")
			}
		} else {
			assert(off+6 <= 4096, "structural invariant interior header bounds")
			childPage := binary.LittleEndian.Uint32(page[off : off+4])
			keyLen := int(binary.LittleEndian.Uint16(page[off+4 : off+6]))
			assert(off+6+keyLen <= 4096, "structural invariant interior key bounds")
			collectTreePages(path, childPage, treePages, overflowPages)
		}
	}
	if pageType == 1 {
		assert(binary.LittleEndian.Uint32(page[4:8]) == 0, "structural invariant leaf right child must be zero")
	}
	if pageType == 2 {
		rightChild := binary.LittleEndian.Uint32(page[4:8])
		assert(rightChild != 0, "structural invariant interior right child")
		collectTreePages(path, rightChild, treePages, overflowPages)
	}
}

func collectOverflowPages(path string, pageID uint32, overflowPages map[uint32]bool) {
	current := pageID
	for current != 0 {
		assert(!overflowPages[current], "structural invariant overflow cycle")
		overflowPages[current] = true
		page := readPageBytes(path, current)
		assert(page[0] == 4, "structural invariant overflow page type")
		dataLen := int(binary.LittleEndian.Uint16(page[8:10]))
		assert(10+dataLen <= 4096, "structural invariant overflow length")
		current = binary.LittleEndian.Uint32(page[4:8])
	}
}

func collectFreePages(path string, pageID uint32, freePages map[uint32]bool) {
	current := pageID
	for current != 0 {
		assert(!freePages[current], "structural invariant free list cycle")
		freePages[current] = true
		page := readPageBytes(path, current)
		if page[0] == 3 {
			current = binary.LittleEndian.Uint32(page[4:8])
			continue
		}
		assert(page[0] == 5, "structural invariant free list page type")
		count := int(binary.LittleEndian.Uint16(page[8:10]))
		assert(10+count*4 <= 4096, "structural invariant pending free payload bounds")
		pos := 10
		for i := 0; i < count; i++ {
			id := binary.LittleEndian.Uint32(page[pos : pos+4])
			assert(id != 0, "structural invariant pending free page id")
			assert(!freePages[id], "structural invariant pending free duplicate page")
			freePages[id] = true
			pos += 4
		}
		current = binary.LittleEndian.Uint32(page[4:8])
	}
}

func assertModelBytesMatchesStore(db *vostore.Store, model map[string][]byte) {
	n, err := db.Len()
	assert(err == nil, "model bytes parity len err")
	assert(n == len(model), "model bytes parity len")

	keys, err := db.Keys("")
	assert(err == nil, "model bytes parity keys err")
	expectedKeys := sortedModelKeysBytes(model)
	assert(len(keys) == len(expectedKeys), "model bytes parity keys count")
	for i := 0; i < len(keys); i++ {
		assert(keys[i] == expectedKeys[i], "model bytes parity key order")
		value, ok, getErr := db.GetBytes(keys[i])
		assert(getErr == nil, "model bytes parity key get err")
		assert(ok, "model bytes parity key should exist")
		assert(bytesEqual(value, model[keys[i]]), "model bytes parity key value")
	}

	for key, expected := range model {
		value, ok, getErr := db.GetBytes(key)
		assert(getErr == nil, "model bytes parity direct get err")
		assert(ok, "model bytes parity direct get exists")
		assert(bytesEqual(value, expected), "model bytes parity direct get value")
		has, hasErr := db.Has(key)
		assert(hasErr == nil, "model bytes parity direct has err")
		assert(has, "model bytes parity direct has exists")
	}

	missingKey := "blob-missing"
	_, exists := model[missingKey]
	assert(!exists, "model bytes parity missing key assumption")
	_, ok, getErr := db.GetBytes(missingKey)
	assert(getErr == nil, "model bytes parity missing get err")
	assert(!ok, "model bytes parity missing get")
	has, hasErr := db.Has(missingKey)
	assert(hasErr == nil, "model bytes parity missing has err")
	assert(!has, "model bytes parity missing has")

	for prefixDigit := 0; prefixDigit < 3; prefixDigit++ {
		prefix := fmt.Sprintf("blob-%1d", prefixDigit)
		prefixKeys, prefixErr := db.Keys(prefix)
		assert(prefixErr == nil, "model bytes parity prefix keys err")
		expectedPrefixKeys := filteredModelKeysBytes(model, prefix)
		assert(len(prefixKeys) == len(expectedPrefixKeys), "model bytes parity prefix keys count")
		for i := 0; i < len(prefixKeys); i++ {
			assert(prefixKeys[i] == expectedPrefixKeys[i], "model bytes parity prefix key order")
		}
	}
}

func sortedModelKeysBytes(model map[string][]byte) []string {
	keys := make([]string, 0, len(model))
	for key := range model {
		keys = append(keys, key)
	}
	for i := 1; i < len(keys); i++ {
		j := i
		for j > 0 && keys[j] < keys[j-1] {
			keys[j], keys[j-1] = keys[j-1], keys[j]
			j--
		}
	}
	return keys
}

func filteredModelKeysBytes(model map[string][]byte, prefix string) []string {
	keys := make([]string, 0)
	for key := range model {
		if len(key) >= len(prefix) && key[:len(prefix)] == prefix {
			keys = append(keys, key)
		}
	}
	for i := 1; i < len(keys); i++ {
		j := i
		for j > 0 && keys[j] < keys[j-1] {
			keys[j], keys[j-1] = keys[j-1], keys[j]
			j--
		}
	}
	return keys
}

func cloneTestBytes(src []byte) []byte {
	if src == nil {
		return nil
	}
	dst := make([]byte, len(src))
	copy(dst, src)
	return dst
}

func bytesEqual(a, b []byte) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func testBytesForState(seed uint32, step int, state uint32) []byte {
	length := int(state%5000) + 1
	if step%7 == 0 {
		length = 4300 + int(state%1400)
	}
	if step%11 == 0 {
		length = 16 + int(state%96)
	}
	data := make([]byte, length)
	base := state + seed*97 + uint32(step)*13
	for i := 0; i < len(data); i++ {
		data[i] = byte((base + uint32(i)*17 + uint32(i/7)*29) % 251)
	}
	return data
}

func rewriteHeaderChecksum(buf []byte) {
	binary.LittleEndian.PutUint32(buf[testOffChecksum:], testCRC32(buf[:testOffChecksum]))
}

func testCRC32(data []byte) uint32 {
	crc := uint32(0xFFFFFFFF)
	for _, b := range data {
		crc ^= uint32(b)
		for i := 0; i < 8; i++ {
			if crc&1 != 0 {
				crc = (crc >> 1) ^ 0xEDB88320
			} else {
				crc >>= 1
			}
		}
	}
	return crc ^ 0xFFFFFFFF
}
