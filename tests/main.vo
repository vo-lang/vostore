func testBtreeCycleDetected(tmpDir string) {
	path := filepath.Join(tmpDir, "btree_cycle_detected.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for btree cycle detected")

	err = db.Update(func(tx *vostore.Tx) error {
		for i := 0; i < 400; i++ {
			key := padNum(i, 4)
			tx.Set(key, key)?
		}
		return nil
	})
	assert(err == nil, "populate db for btree cycle detected")
	err = db.Close()
	assert(err == nil, "close db for btree cycle detected")

	rootPage := readPrimaryRootPage(path)
	page := readPageBytes(path, rootPage)
	assert(page[0] == 2, "root should be an interior page for btree cycle detected")
	binary.LittleEndian.PutUint32(page[4:8], rootPage)
	err = writePageBytes(path, rootPage, page)
	assert(err == nil, "rewrite root right child into a cycle")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for btree cycle detected")
	_, _, err = db.Get("zzzz")
	assert(err != nil, "btree cycle should fail on search")
	_, err = db.Len()
	assert(err != nil, "btree cycle should fail on count")
	err = db.Close()
	assert(err == nil, "close db for btree cycle detected")
}

func testLatestHeaderRecovery(tmpDir string) {
	path := filepath.Join(tmpDir, "latest_header_recovery.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for latest header recovery")
	err = db.Set("persist", "yes")
	assert(err == nil, "set value for latest header recovery")
	err = db.Close()
	assert(err == nil, "close db for latest header recovery")

	buf := readHeaderBytes(path)
	shadowTxID := binary.LittleEndian.Uint32(buf[testHeaderSize+testOffTxID:])
	assert(shadowTxID > 0, "shadow txID should be non-zero")
	binary.LittleEndian.PutUint32(buf[testOffRootPage:], 0)
	binary.LittleEndian.PutUint32(buf[testOffTxID:], shadowTxID-1)
	rewriteHeaderChecksum(buf[:testHeaderSize])
	err = writeHeaderBytes(path, buf)
	assert(err == nil, "rewrite primary header for latest header recovery")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for latest header recovery")
	val, ok, err := db.Get("persist")
	assert(err == nil, "get persisted value after latest header recovery")
	assert(ok, "persisted value should exist after latest header recovery")
	assert(val == "yes", "persisted value after latest header recovery")
	err = db.Close()
	assert(err == nil, "close recovered db for latest header recovery")

	buf = readHeaderBytes(path)
	primaryTxID := binary.LittleEndian.Uint32(buf[testOffTxID:])
	shadowTxID = binary.LittleEndian.Uint32(buf[testHeaderSize+testOffTxID:])
	assert(primaryTxID == shadowTxID, "header copies should be repaired to same txID")
	assert(binary.LittleEndian.Uint32(buf[testOffRootPage:]) != 0, "primary header rootPage should be repaired")
}

