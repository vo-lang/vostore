package main

import (
	"encoding/binary"
	"fmt"
	"github.com/vo-lang/vostore"
	"os"
	"path/filepath"
)

func main() {
	tmpDir, err := os.MkdirTemp("", "vo-test-vostore-*")
	assert(err == nil, "create temp dir")
	defer os.RemoveAll(tmpDir)

	testBasicCRUD(tmpDir)
	testGetBytesIsolation(tmpDir)
	testBatchOps(tmpDir)
	testBatchRollback(tmpDir)
	testBatchOverwriteRollback(tmpDir)
	testBatchDeleteRollback(tmpDir)
	testOverwrite(tmpDir)
	testKeys(tmpDir)
	testPrefixKeys(tmpDir)
	testLen(tmpDir)
	testClear(tmpDir)
	testClearReopen(tmpDir)
	testTransactionalClear(tmpDir)
	testClearRollback(tmpDir)
	testPersistence(tmpDir)
	testManyKeys(tmpDir)
	testDeepDeleteReinsert(tmpDir)
	testDeleteCollapseRootAndReexpand(tmpDir)
	testDeleteRefreshesMiddleSeparators(tmpDir)
	testDeleteNonExistent(tmpDir)
	testEmptyStore(tmpDir)
	testLargeValue(tmpDir)
	testOverflowOverwrite(tmpDir)
	testOverflowDelete(tmpDir)
	testLargeKeyOverflow(tmpDir)
	testKeyValidation(tmpDir)
	testCorruptRootPageType(tmpDir)
	testBtreeCycleDetected(tmpDir)
	testLatestHeaderRecovery(tmpDir)
	testInvalidPageSizeHeader(tmpDir)
	testLargeKeyInteriorRootSplit(tmpDir)
	testFreeListReuse(tmpDir)
	testPendingFreeRecovery(tmpDir)
	testOverflowCycleDetected(tmpDir)
	testModelRandomOps(tmpDir)
	testModelRandomBytesOps(tmpDir)
	testTransactionCleanupOnPanic(tmpDir)
}

func testBasicCRUD(tmpDir string) {
	path := filepath.Join(tmpDir, "crud.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for crud")

	err = db.Set("name", "Alice")
	assert(err == nil, "set name")

	val, ok, err := db.Get("name")
	assert(err == nil, "get name err")
	assert(ok, "get name found")
	assert(val == "Alice", "get name value")

	has, err := db.Has("name")
	assert(err == nil, "has name err")
	assert(has, "has name")
	has, err = db.Has("missing")
	assert(err == nil, "has missing err")
	assert(!has, "has missing")

	found, err := db.Delete("name")
	assert(err == nil, "delete name")
	assert(found, "delete found")

	_, ok, err = db.Get("name")
	assert(err == nil, "get after delete err")
	assert(!ok, "get after delete")

	err = db.Close()
	assert(err == nil, "close crud db")
}

func testGetBytesIsolation(tmpDir string) {
	path := filepath.Join(tmpDir, "getbytes_isolation.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for getbytes isolation")

	err = db.SetBytes("key", []byte{1, 2, 3})
	assert(err == nil, "set bytes for getbytes isolation")

	got, ok, err := db.GetBytes("key")
	assert(err == nil, "get bytes for getbytes isolation err")
	assert(ok, "get bytes for getbytes isolation found")
	got[0] = 9

	again, ok, err := db.GetBytes("key")
	assert(err == nil, "get bytes again for getbytes isolation err")
	assert(ok, "get bytes again for getbytes isolation found")
	assert(len(again) == 3, "getbytes isolation length")
	assert(again[0] == 1, "getbytes isolation byte 0")
	assert(again[1] == 2, "getbytes isolation byte 1")
	assert(again[2] == 3, "getbytes isolation byte 2")

	err = db.Close()
	assert(err == nil, "close db for getbytes isolation")
}

func testBatchOps(tmpDir string) {
	path := filepath.Join(tmpDir, "batch.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for batch")

	err = db.Update(func(tx *vostore.Tx) error {
		tx.Set("a", "1")?
		tx.Set("b", "2")?
		tx.Set("c", "3")?
		return nil
	})
	assert(err == nil, "batch set")

	val, ok, err := db.Get("a")
	assert(err == nil, "batch get a err")
	assert(ok, "batch get a")
	assert(val == "1", "batch get a value")

	val, ok, err = db.Get("c")
	assert(err == nil, "batch get c err")
	assert(ok, "batch get c")
	assert(val == "3", "batch get c value")

	n, err := db.Len()
	assert(err == nil, "batch len err")
	assert(n == 3, "batch len")

	err = db.Close()
	assert(err == nil, "close batch db")
}

func testBatchRollback(tmpDir string) {
	path := filepath.Join(tmpDir, "batch_rollback.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for batch rollback")

	// Pre-populate one key
	err = db.Set("existing", "before")
	assert(err == nil, "set existing")

	// Batch that inserts some keys, then fails on empty key
	err = db.Update(func(tx *vostore.Tx) error {
		tx.Set("new1", "val1")?
		tx.Set("new2", "val2")?
		tx.Set("", "should fail")?
		return nil
	})
	assert(err != nil, "batch should fail on empty key")

	// After rollback: "new1" and "new2" should NOT exist
	_, ok, err := db.Get("new1")
	assert(err == nil, "get new1 err")
	assert(!ok, "new1 should not exist after rollback")
	_, ok, err = db.Get("new2")
	assert(err == nil, "get new2 err")
	assert(!ok, "new2 should not exist after rollback")

	// "existing" should still be there
	val, ok, err := db.Get("existing")
	assert(err == nil, "get existing err")
	assert(ok, "existing should survive rollback")
	assert(val == "before", "existing value after rollback")

	err = db.Close()
	assert(err == nil, "close batch rollback db")
}

func testBatchOverwriteRollback(tmpDir string) {
	path := filepath.Join(tmpDir, "batch_overwrite_rollback.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for batch overwrite rollback")

	err = db.Set("existing", "before")
	assert(err == nil, "set existing for overwrite rollback")

	err = db.Update(func(tx *vostore.Tx) error {
		tx.Set("existing", "after")?
		tx.Set("", "fail")?
		return nil
	})
	assert(err != nil, "batch overwrite rollback should fail")

	val, ok, err := db.Get("existing")
	assert(err == nil, "get existing after overwrite rollback err")
	assert(ok, "existing should exist after overwrite rollback")
	assert(val == "before", "existing value after overwrite rollback")

	err = db.Close()
	assert(err == nil, "close batch overwrite rollback db")
}

func testBatchDeleteRollback(tmpDir string) {
	path := filepath.Join(tmpDir, "batch_delete_rollback.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for batch delete rollback")

	err = db.Set("existing", "before")
	assert(err == nil, "set existing for delete rollback")

	err = db.Update(func(tx *vostore.Tx) error {
		_, deleteErr := tx.Delete("existing")
		deleteErr?
		tx.Set("", "fail")?
		return nil
	})
	assert(err != nil, "batch delete rollback should fail")

	val, ok, err := db.Get("existing")
	assert(err == nil, "get existing after delete rollback err")
	assert(ok, "existing should exist after delete rollback")
	assert(val == "before", "existing value after delete rollback")

	err = db.Close()
	assert(err == nil, "close batch delete rollback db")
}

