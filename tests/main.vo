func testPrefixKeys(tmpDir string) {
	path := filepath.Join(tmpDir, "prefix.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for prefix")

	err = db.Update(func(tx *vostore.Tx) error {
		tx.Set("user:1:name", "Alice")?
		tx.Set("user:1:email", "alice@example.com")?
		tx.Set("user:2:name", "Bob")?
		tx.Set("config:theme", "dark")?
		return nil
	})
	assert(err == nil, "batch set for prefix")

	userKeys, err := db.Keys("user:1:")
	assert(err == nil, "prefix user:1: err")
	assert(len(userKeys) == 2, "prefix user:1: count")

	configKeys, err := db.Keys("config:")
	assert(err == nil, "prefix config: err")
	assert(len(configKeys) == 1, "prefix config: count")
	assert(configKeys[0] == "config:theme", "prefix config key")

	err = db.Close()
	assert(err == nil, "close prefix db")
}

func testLen(tmpDir string) {
	path := filepath.Join(tmpDir, "len.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for len")

	n, err := db.Len()
	assert(err == nil, "empty len err")
	assert(n == 0, "empty len")

	db.Set("a", "1")
	n, err = db.Len()
	assert(err == nil, "len after 1 err")
	assert(n == 1, "len after 1 insert")

	db.Set("b", "2")
	n, err = db.Len()
	assert(err == nil, "len after 2 err")
	assert(n == 2, "len after 2 inserts")

	db.Delete("a")
	n, err = db.Len()
	assert(err == nil, "len after delete err")
	assert(n == 1, "len after delete")

	err = db.Close()
	assert(err == nil, "close len db")
}

func testClear(tmpDir string) {
	path := filepath.Join(tmpDir, "clear.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for clear")

	db.Set("x", "1")
	db.Set("y", "2")
	n, err := db.Len()
	assert(err == nil, "len before clear err")
	assert(n == 2, "len before clear")

	err = db.Clear()
	assert(err == nil, "clear")
	n, err = db.Len()
	assert(err == nil, "len after clear err")
	assert(n == 0, "len after clear")
	has, err := db.Has("x")
	assert(err == nil, "has after clear err")
	assert(!has, "has after clear")

	// Can still use after clear
	db.Set("z", "3")
	n, err = db.Len()
	assert(err == nil, "len after re-insert err")
	assert(n == 1, "len after re-insert")

	err = db.Close()
	assert(err == nil, "close clear db")
}

func testClearReopen(tmpDir string) {
	path := filepath.Join(tmpDir, "clear_reopen.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for clear reopen")
	err = db.Set("x", "1")
	assert(err == nil, "set before clear reopen")
	err = db.Clear()
	assert(err == nil, "clear before reopen")
	err = db.Close()
	assert(err == nil, "close db after clear before reopen")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db after clear")
	n, err := db.Len()
	assert(err == nil, "len after clear reopen err")
	assert(n == 0, "len after clear reopen")
	err = db.Set("y", "2")
	assert(err == nil, "set after clear reopen")
	val, ok, err := db.Get("y")
	assert(err == nil, "get after clear reopen err")
	assert(ok, "get after clear reopen found")
	assert(val == "2", "get after clear reopen value")
	err = db.Close()
	assert(err == nil, "close db after clear reopen")
}

func testTransactionalClear(tmpDir string) {
	path := filepath.Join(tmpDir, "tx_clear.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for transactional clear")

	err = db.Set("before", "1")
	assert(err == nil, "seed value for transactional clear")

	err = db.Update(func(tx *vostore.Tx) error {
		tx.Clear()?
		_, ok, err := tx.Get("before")
		assert(err == nil, "get cleared key inside transactional clear")
		assert(!ok, "cleared key should disappear inside transaction")
		tx.Set("after", "2")?
		n, err := tx.Len()
		assert(err == nil, "len after transactional clear")
		assert(n == 1, "len after transactional clear")
		return nil
	})
	assert(err == nil, "transactional clear should commit")

	_, ok, err := db.Get("before")
	assert(err == nil, "get old key after transactional clear err")
	assert(!ok, "old key should be removed after transactional clear")
	val, ok, err := db.Get("after")
	assert(err == nil, "get new key after transactional clear err")
	assert(ok, "new key should exist after transactional clear")
	assert(val == "2", "new key value after transactional clear")

	err = db.Close()
	assert(err == nil, "close db for transactional clear")
}

func testClearRollback(tmpDir string) {
	path := filepath.Join(tmpDir, "clear_rollback.vokv")
	db, err := vostore.Open(path)
