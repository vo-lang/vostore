		return nil
	})
	assert(err != nil, "clear rollback should fail")

	val, ok, err := db.Get("existing")
	assert(err == nil, "get existing after clear rollback err")
	assert(ok, "existing should survive clear rollback")
	assert(val == "before", "existing value after clear rollback")

	err = db.Close()
	assert(err == nil, "close db for clear rollback")
}

func testPersistence(tmpDir string) {
	path := filepath.Join(tmpDir, "persist.vokv")

	// Write and close
	db, err := vostore.Open(path)
	assert(err == nil, "open db for persist write")
	db.Set("persist", "yes")
	db.Set("count", "42")
	err = db.Close()
	assert(err == nil, "close persist write")

	// Reopen and read
	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for persist read")

	val, ok, err := db.Get("persist")
	assert(err == nil, "persist get err")
	assert(ok, "persist found after reopen")
	assert(val == "yes", "persist value after reopen")

	val, ok, err = db.Get("count")
	assert(err == nil, "count get err")
	assert(ok, "count found after reopen")
	assert(val == "42", "count value after reopen")

	err = db.Close()
	assert(err == nil, "close persist read")
}

func testManyKeys(tmpDir string) {
	path := filepath.Join(tmpDir, "many.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for many keys")

	// Insert 200 keys to trigger multiple splits
	count := 200
	err = db.Update(func(tx *vostore.Tx) error {
		for i := 0; i < count; i++ {
			key := padNum(i, 4)
			tx.Set(key, key)?
		}
		return nil
	})
	assert(err == nil, "batch insert many")
	n, err := db.Len()
	assert(err == nil, "many keys len err")
	assert(n == count, "many keys len")

	// Verify all keys exist
	for i := 0; i < count; i++ {
		key := padNum(i, 4)
		val, ok, err := db.Get(key)
		assert(err == nil, "many get err "+key)
		assert(ok, "many get "+key)
		assert(val == key, "many value "+key)
	}

	// Delete half
	for i := 0; i < count; i += 2 {
		key := padNum(i, 4)
		found, err := db.Delete(key)
		assert(err == nil, "many delete "+key)
		assert(found, "many delete found "+key)
	}
	n, err = db.Len()
	assert(err == nil, "many len after delete err")
	assert(n == count/2, "many len after delete half")

	// Verify remaining
	for i := 1; i < count; i += 2 {
		key := padNum(i, 4)
		val, ok, err := db.Get(key)
		assert(err == nil, "many get remaining err "+key)
		assert(ok, "many get remaining "+key)
		assert(val == key, "many value remaining "+key)
	}

	err = db.Close()
	assert(err == nil, "close many db")
}

func testDeepDeleteReinsert(tmpDir string) {
	path := filepath.Join(tmpDir, "deep_delete_reinsert.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for deep delete reinsert")

	count := 80
	deleteStart := 20
	deleteEnd := 60
	err = db.Update(func(tx *vostore.Tx) error {
		for i := 0; i < count; i++ {
			key := "item:" + padNum(i, 4)
			tx.Set(key, largeTreeValue(key))?
		}
		return nil
	})
	assert(err == nil, "populate db for deep delete reinsert")

	for i := deleteStart; i < deleteEnd; i++ {
		key := "item:" + padNum(i, 4)
		found, deleteErr := db.Delete(key)
		assert(deleteErr == nil, "delete key for deep delete reinsert")
		assert(found, "delete found for deep delete reinsert")
	}

	n, err := db.Len()
	assert(err == nil, "len after deep delete reinsert deletes")
	assert(n == count-(deleteEnd-deleteStart), "len after deep delete reinsert deletes")
	assertStructuralInvariants(path)

	err = db.Close()
	assert(err == nil, "close db after deletes for deep delete reinsert")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db after deletes for deep delete reinsert")

	for i := 0; i < deleteStart; i++ {
		key := "item:" + padNum(i, 4)
		val, ok, getErr := db.Get(key)
		assert(getErr == nil, "get low retained key after deep delete reinsert")
		assert(ok, "low retained key should exist after deep delete reinsert")
		assert(val == largeTreeValue(key), "low retained key value after deep delete reinsert")
	}
	for i := deleteStart; i < deleteEnd; i++ {
		key := "item:" + padNum(i, 4)
		_, ok, getErr := db.Get(key)
		assert(getErr == nil, "get deleted key after deep delete reinsert")
		assert(!ok, "deleted key should be absent after deep delete reinsert")
	}
	for i := deleteEnd; i < count; i++ {
		key := "item:" + padNum(i, 4)
		val, ok, getErr := db.Get(key)
		assert(getErr == nil, "get high retained key after deep delete reinsert")
		assert(ok, "high retained key should exist after deep delete reinsert")
		assert(val == largeTreeValue(key), "high retained key value after deep delete reinsert")
	}

	err = db.Update(func(tx *vostore.Tx) error {
		for i := deleteStart; i < deleteEnd; i++ {
			key := "item:" + padNum(i, 4)
			value := largeTreeValue("new:" + padNum(i, 4))
			tx.Set(key, value)?
		}
		return nil
	})
	assert(err == nil, "reinsert deleted range for deep delete reinsert")

	n, err = db.Len()
	assert(err == nil, "len after deep delete reinsert reinserts")
	assert(n == count, "len after deep delete reinsert reinserts")
	assertStructuralInvariants(path)

	keys, err := db.Keys("item:")
	assert(err == nil, "keys after deep delete reinsert")
	assert(len(keys) == count, "keys count after deep delete reinsert")
	for i := 0; i < count; i++ {
		expectedKey := "item:" + padNum(i, 4)
		assert(keys[i] == expectedKey, "key order after deep delete reinsert")
		val, ok, getErr := db.Get(expectedKey)
		assert(getErr == nil, "get after deep delete reinsert final")
		assert(ok, "final key should exist after deep delete reinsert")
		if i >= deleteStart && i < deleteEnd {
			assert(val == largeTreeValue("new:"+padNum(i, 4)), "final reinserted value after deep delete reinsert")
		} else {
			assert(val == largeTreeValue(expectedKey), "final retained value after deep delete reinsert")
		}
	}

	err = db.Close()
	assert(err == nil, "close db for deep delete reinsert")
}

func testDeleteCollapseRootAndReexpand(tmpDir string) {
	path := filepath.Join(tmpDir, "delete_collapse_root_reexpand.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for delete collapse root reexpand")

	count := 80
	err = db.Update(func(tx *vostore.Tx) error {
		for i := 0; i < count; i++ {
			key := "item:" + padNum(i, 4)
			tx.Set(key, largeTreeValue(key))?
		}
		return nil
	})
	assert(err == nil, "populate db for delete collapse root reexpand")
	assertStructuralInvariants(path)
	initialRoot := readPageBytes(path, readPrimaryRootPage(path))
	assert(initialRoot[0] == 2, "root starts as interior before delete collapse root reexpand")

	for i := 0; i < count-1; i++ {
		key := "item:" + padNum(i, 4)
		found, deleteErr := db.Delete(key)
		assert(deleteErr == nil, "delete key for delete collapse root reexpand")
		assert(found, "delete found for delete collapse root reexpand")
	}

	n, err := db.Len()
	assert(err == nil, "len after delete collapse root reexpand deletes")
	assert(n == 1, "len after delete collapse root reexpand deletes")
	val, ok, err := db.Get("item:" + padNum(count-1, 4))
	assert(err == nil, "get survivor after delete collapse root reexpand")
	assert(ok, "survivor exists after delete collapse root reexpand")
	assert(val == largeTreeValue("item:"+padNum(count-1, 4)), "survivor value after delete collapse root reexpand")
	assertStructuralInvariants(path)

	rootPage := readPrimaryRootPage(path)
	assert(rootPage != 0, "root page exists after delete collapse root reexpand")
	root := readPageBytes(path, rootPage)
	assert(root[0] == 1, "root collapses to leaf after delete collapse root reexpand")
	assert(binary.LittleEndian.Uint16(root[2:4]) == 1, "collapsed root leaf cell count after delete collapse root reexpand")
	assert(binary.LittleEndian.Uint32(root[4:8]) == 0, "collapsed root next leaf pointer after delete collapse root reexpand")

	err = db.Update(func(tx *vostore.Tx) error {
		for i := 0; i < count-1; i++ {
			key := "item:" + padNum(i, 4)
			value := largeTreeValue("new:" + padNum(i, 4))
			tx.Set(key, value)?
		}
		return nil
	})
	assert(err == nil, "reinsert keys for delete collapse root reexpand")

	n, err = db.Len()
	assert(err == nil, "len after delete collapse root reexpand reinserts")
	assert(n == count, "len after delete collapse root reexpand reinserts")
	assertStructuralInvariants(path)
	reexpandedRoot := readPageBytes(path, readPrimaryRootPage(path))
	assert(reexpandedRoot[0] == 2, "root reexpands to interior after delete collapse root reexpand")

	keys, err := db.Keys("item:")
	assert(err == nil, "keys after delete collapse root reexpand")
	assert(len(keys) == count, "keys count after delete collapse root reexpand")
	for i := 0; i < count; i++ {
		expectedKey := "item:" + padNum(i, 4)
		assert(keys[i] == expectedKey, "key order after delete collapse root reexpand")
		got, exists, getErr := db.Get(expectedKey)
		assert(getErr == nil, "get after delete collapse root reexpand")
		assert(exists, "key exists after delete collapse root reexpand")
		if i == count-1 {
			assert(got == largeTreeValue(expectedKey), "survivor value after delete collapse root reexpand reinserts")
		} else {
			assert(got == largeTreeValue("new:"+padNum(i, 4)), "reinserted value after delete collapse root reexpand")
		}
	}

	err = db.Close()
	assert(err == nil, "close db for delete collapse root reexpand")
}

func testDeleteRefreshesMiddleSeparators(tmpDir string) {
	path := filepath.Join(tmpDir, "delete_refreshes_middle_separators.vokv")
	db, err := vostore.Open(path)
	assert(err == nil, "open db for delete refreshes middle separators")

	count := 80
	deleteStart := 25
	deleteEnd := 55
	err = db.Update(func(tx *vostore.Tx) error {
		for i := 0; i < count; i++ {
			key := "item:" + padNum(i, 4)
			tx.Set(key, largeTreeValue(key))?
		}
		return nil
	})
	assert(err == nil, "populate db for delete refreshes middle separators")

	for i := deleteStart; i < deleteEnd; i++ {
		key := "item:" + padNum(i, 4)
		found, deleteErr := db.Delete(key)
		assert(deleteErr == nil, "delete key for delete refreshes middle separators")
		assert(found, "delete found for delete refreshes middle separators")
	}

	n, err := db.Len()
	assert(err == nil, "len after delete refreshes middle separators")
	assert(n == count-(deleteEnd-deleteStart), "len after delete refreshes middle separators")
	assertStructuralInvariants(path)

	rootPage := readPrimaryRootPage(path)
	assert(rootPage != 0, "root page exists after delete refreshes middle separators")
	root := readPageBytes(path, rootPage)
	assert(root[0] == 2, "root remains interior after delete refreshes middle separators")

	err = db.Close()
	assert(err == nil, "close db for delete refreshes middle separators")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for delete refreshes middle separators")
	assertStructuralInvariants(path)

	for i := 0; i < deleteStart; i++ {
		key := "item:" + padNum(i, 4)
		val, ok, getErr := db.Get(key)
		assert(getErr == nil, "get low retained key after delete refreshes middle separators")
		assert(ok, "low retained key should exist after delete refreshes middle separators")
		assert(val == largeTreeValue(key), "low retained key value after delete refreshes middle separators")
	}
	for i := deleteStart; i < deleteEnd; i++ {
		key := "item:" + padNum(i, 4)
		_, ok, getErr := db.Get(key)
		assert(getErr == nil, "get deleted middle key after delete refreshes middle separators")
		assert(!ok, "deleted middle key should be absent after delete refreshes middle separators")
	}
	for i := deleteEnd; i < count; i++ {
		key := "item:" + padNum(i, 4)
		val, ok, getErr := db.Get(key)
		assert(getErr == nil, "get high retained key after delete refreshes middle separators")
		assert(ok, "high retained key should exist after delete refreshes middle separators")
		assert(val == largeTreeValue(key), "high retained key value after delete refreshes middle separators")
	}

	keys, err := db.Keys("item:")
	assert(err == nil, "keys after delete refreshes middle separators")
	assert(len(keys) == count-(deleteEnd-deleteStart), "keys count after delete refreshes middle separators")
	for i := 0; i < deleteStart; i++ {
		assert(keys[i] == "item:"+padNum(i, 4), "low key order after delete refreshes middle separators")
	}
	for i := deleteEnd; i < count; i++ {
		assert(keys[i-(deleteEnd-deleteStart)] == "item:"+padNum(i, 4), "high key order after delete refreshes middle separators")
	}

	err = db.Close()
	assert(err == nil, "close reopened db for delete refreshes middle separators")
}

