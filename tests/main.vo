	err = db.SetBytes("big", second)
	assert(err == nil, "overwrite overflow value")
	err = db.SetBytes("other", first)
	assert(err == nil, "set second key after overflow overwrite")

	got, ok, err := db.GetBytes("big")
	assert(err == nil, "get overwritten overflow value err")
	assert(ok, "get overwritten overflow value found")
	assert(len(got) == len(second), "overwritten overflow value length")
	for i := 0; i < len(got); i++ {
		assert(got[i] == second[i], "overwritten overflow value byte mismatch")
	}

	err = db.Close()
	assert(err == nil, "close db for overflow overwrite")

	db, err = vostore.Open(path)
	assert(err == nil, "reopen db for overflow overwrite")

	got, ok, err = db.GetBytes("big")
	assert(err == nil, "get overwritten overflow value after reopen err")
	assert(ok, "get overwritten overflow value after reopen found")
	assert(len(got) == len(second), "overwritten overflow value after reopen length")
	for i := 0; i < len(got); i++ {
		assert(got[i] == second[i], "overwritten overflow value after reopen byte mismatch")
	}

	got, ok, err = db.GetBytes("other")
	assert(err == nil, "get second key after overflow overwrite err")
	assert(ok, "get second key after overflow overwrite found")
	assert(len(got) == len(first), "second key after overflow overwrite length")
	for i := 0; i < len(got); i++ {
		assert(got[i] == first[i], "second key after overflow overwrite byte mismatch")
	}

	err = db.Close()
	assert(err == nil, "close db for overflow overwrite after reopen")
}

