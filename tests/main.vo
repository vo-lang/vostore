	got, ok, err := db.GetBytes("after")
	assert(err == nil, "get overflow value after delete after reopen err")
	assert(ok, "get overflow value after delete after reopen found")
	assert(len(got) == len(second), "overflow value after delete after reopen length")
	for i := 0; i < len(got); i++ {
		assert(got[i] == second[i], "overflow value after delete after reopen byte mismatch")
	}

	err = db.Close()
	assert(err == nil, "close db for overflow delete after reopen")
}

